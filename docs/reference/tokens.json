{
  "$meta": {
    "source": "https://fora.so/",
    "siteName": "Fora",
    "extractedAt": "2026-07-06",
    "usage": "Landing-page style reference for Polaris. Dark/calm/glass DNA from Fora; accent swapped to Polaris brand purple (#7432ff) to match the Flocus-style app. Adora reference archived in _adora-archive/.",
    "theme": "dark"
  },
  "color": {
    "void-black":   { "$value": "#000000", "$type": "color", "$description": "Page canvas, base of every section" },
    "snow":         { "$value": "#fff3f0", "$type": "color", "$description": "Primary warm off-white text/headline on dark (never pure white for body)" },
    "pure-white":   { "$value": "#ffffff", "$type": "color", "$description": "Secondary headings, high-emphasis text, button text on dark" },
    "ash":          { "$value": "#5e5e5e", "$type": "color", "$description": "Muted helper copy, captions, metadata, disabled" },
    "panel-24":     { "$value": "#242424", "$type": "color", "$description": "Dark card/panel surface fill" },
    "panel-2a":     { "$value": "#2a2a2a", "$type": "color", "$description": "Lifted panel / hover surface / card border on dark" },
    "soft-concrete":{ "$value": "#eeeeee", "$type": "color", "$description": "Light/inverted pill fills" },
    "dusk-charcoal":{ "$value": "#1b2228", "$type": "color", "$description": "Bottom stop of closing atmospheric gradient" },
    "accent":       { "$value": "#7432ff", "$type": "color", "$description": "Polaris brand accent (from Flocus app) — primary CTA, active states, focus rings" },
    "accent-hover": { "$value": "#8b5cff", "$type": "color", "$description": "Hover / lighter accent state" }
  },
  "atmosphere": {
    "mauve":     { "$value": "#c9a9b8", "$type": "color", "$description": "Dusk hero gradient — warm mauve top" },
    "rose":      { "$value": "#a97f86", "$type": "color", "$description": "Dusk hero gradient — dusty rose mid" },
    "charcoal":  { "$value": "#2a2320", "$type": "color", "$description": "Dusk hero gradient — charcoal lower" },
    "black":     { "$value": "#000000", "$type": "color", "$description": "Dusk hero gradient — black base" }
  },
  "font": {
    "inter":         { "$value": "Inter", "$type": "fontFamily", "$description": "Body/UI/headings, weights 400-600, tight tracking -0.04em headings / -0.02em body" },
    "inter-display": { "$value": "Inter Display", "$type": "fontFamily", "$description": "Large display / hero optical variant" },
    "fragment-mono": { "$value": "Fragment Mono", "$type": "fontFamily", "$description": "Mono kicker/label accent; substitute Geist Mono or JetBrains Mono" }
  },
  "typography": {
    "kicker":      { "$value": { "fontFamily": "Fragment Mono", "fontSize": "12px", "fontWeight": 400, "lineHeight": 1.3, "letterSpacing": "0" }, "$type": "typography", "$description": "Mono eyebrow label" },
    "caption":     { "$value": { "fontFamily": "Inter", "fontSize": "14px", "fontWeight": 400, "lineHeight": 1.5, "letterSpacing": "-0.02em" }, "$type": "typography" },
    "body":        { "$value": { "fontFamily": "Inter", "fontSize": "16px", "fontWeight": 400, "lineHeight": 1.5, "letterSpacing": "-0.02em" }, "$type": "typography" },
    "body-lg":     { "$value": { "fontFamily": "Inter", "fontSize": "18px", "fontWeight": 400, "lineHeight": 1.5, "letterSpacing": "-0.02em" }, "$type": "typography" },
    "subheading":  { "$value": { "fontFamily": "Inter", "fontSize": "22px", "fontWeight": 500, "lineHeight": 1.4, "letterSpacing": "-0.03em" }, "$type": "typography" },
    "heading":     { "$value": { "fontFamily": "Inter", "fontSize": "32px", "fontWeight": 500, "lineHeight": 1.35, "letterSpacing": "-0.04em" }, "$type": "typography", "$description": "Section H2 (43.2px lh, -1.28px ls)" },
    "display-sm":  { "$value": { "fontFamily": "Inter", "fontSize": "36px", "fontWeight": 400, "lineHeight": 1.3, "letterSpacing": "-0.04em" }, "$type": "typography", "$description": "Fora hero H1 (understated); Polaris may scale to 56-72px" }
  },
  "spacing": {
    "unit": { "$value": "4px", "$type": "dimension" },
    "gutter": { "$value": "24px", "$type": "dimension", "$description": "Horizontal section padding" },
    "4": { "$value": "4px", "$type": "dimension" },
    "8": { "$value": "8px", "$type": "dimension" },
    "12": { "$value": "12px", "$type": "dimension" },
    "16": { "$value": "16px", "$type": "dimension" },
    "24": { "$value": "24px", "$type": "dimension" },
    "32": { "$value": "32px", "$type": "dimension" },
    "48": { "$value": "48px", "$type": "dimension" },
    "64": { "$value": "64px", "$type": "dimension" },
    "96": { "$value": "96px", "$type": "dimension", "$description": "Section vertical rhythm" }
  },
  "radius": {
    "xs":      { "$value": "3px", "$type": "dimension", "$description": "Micro insets/inputs" },
    "control": { "$value": "9px", "$type": "dimension", "$description": "Small controls" },
    "media":   { "$value": "15px", "$type": "dimension", "$description": "Product/media frames" },
    "card":    { "$value": "16px", "$type": "dimension", "$description": "Cards/panels" },
    "chip":    { "$value": "9999px", "$type": "dimension", "$description": "Section tags/kicker chips" },
    "pill":    { "$value": "9999px", "$type": "dimension", "$description": "CTA/stadium buttons" }
  },
  "surface": {
    "void-canvas":  { "$value": "#000000", "$type": "color", "$description": "Level 0: page background" },
    "panel":        { "$value": "#242424", "$type": "color", "$description": "Level 1: cards, frames" },
    "lifted-panel": { "$value": "#2a2a2a", "$type": "color", "$description": "Level 2: hover, borders" },
    "atmosphere":   { "$value": "linear-gradient(180deg,#c9a9b8,#a97f86,#2a2320,#000000)", "$type": "color", "$description": "Level 3: decorative dusk wash" }
  },
  "effect": {
    "glass-blur":       { "$value": "blur(5px)", "$type": "other", "$description": "backdrop-filter on floating pills/nav" },
    "closing-gradient": { "$value": "linear-gradient(180deg,#000000 0%,#1b2228 100%)", "$type": "other", "$description": "Closing CTA section background" }
  }
}
